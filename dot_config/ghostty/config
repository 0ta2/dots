# theme
theme = kanagawa-paper-ink

# font
font-family = "HackGen35 Console NF"
window-title-font-family = "HackGen35 Console NF"
font-size = 15

# macOS
macos-option-as-alt = true

# 閉じる際に確認ダイアログを出すかどうか
confirm-close-surface = false

# 非表示･非表示をショートカットで実施
# NOTE: Karabiner-Elements で、f19をカスタマイズしている。
keybind = global:f19=toggle_visibility

# 背景の透過
background-opacity = 0.95
