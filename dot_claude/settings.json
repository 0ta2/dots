{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "language": "japanese",
    "permissions": {
        "allow": [],
        "deny": [
            "Read(./.env)",
            "Read(./.env.*)",
            "Read(./secrets/**)",
            "Bash(rm -rf:*)",
            "Bash(sudo:*)"
        ],
        "ask": [
            "Bash(git push:*)",
            "Bash(git merge:*)",
            "Bash(git rebase:*)",
            "Bash(curl:*)"
        ]
    },
    "hooks": {
    "Stop": [
        {
            "matcher": "",
            "hooks": [
                {
                    "type": "command",
                    "command": "~/.local/bin/claude-notify 'タスクが完了しました'"
                }
            ]
        }
    ],
    "Notification": [
        {
            "matcher": "",
            "hooks": [
                {
                    "type": "command",
                    "command": "~/.local/bin/claude-notify '入力待ちです'"
                }
            ]
        }
    ]
}}
