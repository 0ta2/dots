{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "language": "japanese",
    "vim": true,
    "voiceEnabled": true,
    "enabledPlugins": {
        "lua-lsp@claude-plugins-official": true,
        "gopls-lsp@claude-plugins-official": true,
        "pyright-lsp@claude-plugins-official": true,
        "superpowers@claude-plugins-official": true
    },
    "statusLine": {
        "type": "command",
        "command": "python3 ~/.claude/statusline.py"
    },
    "permissions": {
        "allow": [
            "Bash(curl:http://localhost*)",
            "Bash(base64:*)",
            "Bash(gh pr view:*)",
            "Bash(gh pr list:*)",
            "Bash(gh pr diff:*)",
            "Bash(gh pr checks:*)",
            "Bash(gh issue view:*)",
            "Bash(gh issue list:*)",
            "Bash(gh repo view:*)",
            "Bash(gh run view:*)",
            "Bash(gh run list:*)",
            "Bash(gh api:*)",
            "Bash(gh search:*)",
            "Bash(go test*)",
            "Bash(git status:*)",
            "Bash(git diff:*)",
            "Bash(git log:*)",
            "Bash(git branch:*)",
            "Bash(git show:*)",
            "Bash(rtk:*)"
        ],
        "deny": [
            "Read(./.env)",
            "Read(./.env.*)",
            "Read(./secrets/**)",
            "Bash(sudo:*)"
        ],
        "ask": [
            "Bash(git push:*)",
            "Bash(git merge:*)",
            "Bash(git rebase:*)"
        ]
    },
    "env": {
        "CLAUDE_CODE_NO_FLICKER": "1"
    },
    "hooks": {
        "Stop": [
            {
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "~/.local/bin/claude-notify 'タスクが完了しました'"
                    }
                ]
            }
        ],
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "rtk hook claude"
                    }
                ]
            }
        ]
    }
}
